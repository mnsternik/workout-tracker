@using WorkoutTracker.Models;
@model WorkoutTracker.Models.Training

@{
    ViewData["Title"] = "Details";
}

<div class="container col-md-8">
    <div class="">
        <div class="d-flex flex-row justify-content-between">
            <div>
                <h4>@Model.Name</h4>
                <p>@Model.Date</p>
            </div>
            <div>
                <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-success">Edit</a>
                <a asp-action="Index" class="btn btn-outline-dark">Back</a>
            </div>
        </div>
        <div>
            <p>@Model?.Description</p>
        </div>
        <hr class="my-4"/>
        <div class="col-md-6 mx-auto">
            @foreach (var exercise in Model!.Exercises)
            {
                <div class="mt-3">
                    <h6>@exercise.Name</h6>
                </div>
                @if (exercise.Type == ExerciseType.Strength)
                {
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Set</th>
                                <th>Reps</th>
                                <th>Weight</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int index = 1;
                            }
                            @foreach (var set in exercise.Sets)
                            {
                                <tr>
                                    <td>@index</td>
                                    <td>@set.Repetitions</td>
                                    <td>@set.Weight<td>
                                </tr>
                                index++;
                            }
                        </tbody>
                    </table>
                }
                @if (exercise.Type == ExerciseType.Cardio)
                {
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Set</th>
                                <th>Duration</th>
                                <th>Distance</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int index = 1;
                            }
                            @foreach (var set in exercise.Sets)
                            {
                                <tr>
                                    <td>@index</td>
                                    <td>@set?.Duration</td>
                                    <td>@set?.Distance</td>
                                </tr>
                                index++;
                            }
                        </tbody>
                    </table>
                }
                @if (exercise.Type == ExerciseType.Isometric)
                {
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Set</th>
                                <th>Duration</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int index = 1;
                            }
                            @foreach (var set in exercise.Sets)
                            {
                                <tr>
                                    <td>@index</td>
                                    <td>@set.Duration</td>
                                </tr>
                                index++;
                            }
                        </tbody>
                    </table>
                }
            }
        </div>
    </div>
</div>
