@model Tuple<int, int> 
@* Tuple of ExerciseID and SetCounter *@

<tr class="set" id="set-@(Model).Item1-@(Model).Item2">
    <th scope="col">@(Model.Item2 + 1)</th>
    <th scope="col" class="form-group">
        <input class="form-control" id="Exercises_@(Model).Item1__Sets_@(Model).Item2__Repetitions" name="Exercises[@Model.Item1].Sets[@Model.Item2].Repetitions" />
    </th>
    <th scope="col" class="form-group">
        <input class="form-control" id="Exercises_@(Model).Item1__Sets_@(Model).Item2__Weight" name="Exercises[@Model.Item1].Sets[@Model.Item2].Weight" />
    </th>
</tr>